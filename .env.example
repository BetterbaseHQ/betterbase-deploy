# Betterbase Production Environment
# Copy to .env and fill in values before running docker compose up

# ==========================================================================
# OPAQUE Authentication Keys (generate with betterbase-accounts keygen)
# ==========================================================================
OPAQUE_SERVER_SETUP=

# ==========================================================================
# OAuth Issuer (your accounts server public URL)
# For production, use: https://accounts.yourdomain.com
# ==========================================================================
OAUTH_ISSUER=http://localhost:5377

# ==========================================================================
# Sync endpoint advertised in discovery metadata
# For production, use: https://sync.yourdomain.com/api/v1
# ==========================================================================
SYNC_ENDPOINT=http://localhost:5379/api/v1

# ==========================================================================
# CAP (Proof-of-Work CAPTCHA)
# ==========================================================================
CAP_ADMIN_KEY=
CAP_KEY_ID=
CAP_SECRET=

# ==========================================================================
# Identity Hash Key (HMAC-SHA256 for privacy-preserving identity hashing)
# Generate: openssl rand -hex 32
# ==========================================================================
IDENTITY_HASH_KEY=

# ==========================================================================
# Database credentials (defaults work for local deployment)
# ==========================================================================
# ACCOUNTS_DB_USER=accounts
# ACCOUNTS_DB_PASSWORD=accounts
# ACCOUNTS_DB_NAME=accounts
# SYNC_DB_USER=sync
# SYNC_DB_PASSWORD=sync
# SYNC_DB_NAME=sync

# ==========================================================================
# Port mapping (defaults: accounts=5377, sync=5379)
# ==========================================================================
# ACCOUNTS_PORT=5377
# SYNC_PORT=5379
